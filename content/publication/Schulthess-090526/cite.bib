@inproceedings{schulthess2025modeling,
    author = {Schulthess, Nico},
    title = {Modeling DINO Embeddings for Fast and Efficient Unsupervised Anomaly Detection in Medical Imaging},
    booktitle = {MICCAI 2025},
    year = {2025},
    url = {https://papers.miccai.org/miccai-2025/paper/2425_paper.pdf},
    abstract = {The goal of unsupervised anomaly detection (UAD) is to model the distribution of images from healthy patients and use this model to identify samples that deviate from the norm. UAD has made another leap using the rich, patch-level representations provided by foundational models like DINOv2 and DINOv3. However, traditional methods often rely on large memory banks of normative features, leading to significant computational and memory overhead during inference, which is particularly critical in medical imaging where the normative distribution shows more variance than in industrial vision applications.}
}
